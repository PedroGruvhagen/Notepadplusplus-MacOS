# Copy this file to scripts/signing.env (which is gitignored) and fill in your
# own Apple signing details. scripts/signing.env must NEVER be committed.
#
# No Apple credentials of any kind are stored in this repository. Each person
# who wants to distribute a signed build supplies their own here.

# Your full "Developer ID Application" identity, exactly as shown by:
#   security find-identity -v -p codesigning
SIGN_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# A notarytool keychain profile name. Create it once (the app-specific password
# comes from https://appleid.apple.com):
#   xcrun notarytool store-credentials "notepadpp-notary" \
#     --apple-id "you@example.com" \
#     --team-id "TEAMID" \
#     --password "xxxx-xxxx-xxxx-xxxx"
NOTARY_PROFILE="notepadpp-notary"

# Optional: override the bundle identifier for your own builds.
# BUNDLE_ID="io.github.yourname.notepadpp"
